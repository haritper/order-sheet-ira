                      "parameters":  {
                                         "jsCode":  "const incoming = $input.first().json || {};\nconst payload = incoming.payload || {};\n\nconst required = [\u0027alert_id\u0027, \u0027entry_id\u0027, \u0027order_code\u0027, \u0027customer_name\u0027, \u0027status\u0027, \u0027deadline_at\u0027, \u0027checked_at\u0027, \u0027target\u0027, \u0027contact\u0027];\nconst missing = required.filter((k) =\u003e payload[k] === undefined || payload[k] === null || String(payload[k]).trim() === \u0027\u0027);\nif (missing.length \u003e 0) {\n  return [{ json: { ok: false, statusCode: 400, error: `Missing required fields: ${missing.join(\u0027, \u0027)}` } }];\n}\n\nconst target = String(payload.target || \u0027\u0027).trim().toUpperCase();\nif (![\u0027GIRI\u0027, \u0027MD\u0027].includes(target)) {\n  return [{ json: { ok: false, statusCode: 400, error: \u0027Invalid target. Allowed values: GIRI, MD\u0027 } }];\n}\n\nconst normalized = {\n  alert_id: String(payload.alert_id),\n  entry_id: Number(payload.entry_id),\n  order_code: String(payload.order_code),\n  customer_name: String(payload.customer_name),\n  status: String(payload.status),\n  deadline_at: String(payload.deadline_at),\n  checked_at: String(payload.checked_at),\n  target,\n  contact: String(payload.contact).replace(/[^0-9]/g, \u0027\u0027)\n};\n\nif (!normalized.contact) {\n  return [{ json: { ok: false, statusCode: 400, error: \u0027Invalid contact format\u0027 } }];\n}\n\nreturn [{ json: { ok: true, statusCode: 200, normalized } }];"
