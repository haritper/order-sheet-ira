                      "parameters":  {
                                         "jsCode":  "const full = $input.first().json || {};\nconst statusCode = Number(full.statusCode || full.code || 502);\nconst body = full.body || {};\nconst ok = statusCode \u003e= 200 \u0026\u0026 statusCode \u003c 300 \u0026\u0026 !body.error;\nconst providerMessageId = body?.messages?.[0]?.id || body?.id || \u0027\u0027;\n\nreturn [{\n  json: {\n    ok,\n    statusCode: ok ? 200 : statusCode,\n    delivery_mode: \u0027whatsapp_template\u0027,\n    delivery_result: ok ? \u0027sent\u0027 : `failed_http_${statusCode}`,\n    provider_message_id: providerMessageId || null,\n    error: ok ? null : (body?.error?.message || full.statusMessage || \u0027Template send failed\u0027)\n  }\n}];"
