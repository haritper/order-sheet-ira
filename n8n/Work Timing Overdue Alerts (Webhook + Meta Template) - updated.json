                  {
                      "parameters":  {
                                         "jsCode":  "const normalized = $input.first().json.normalized;\n\nconst templateName = \u0027work_timing_alert\u0027;\nconst deadlineDate = new Date(normalized.deadline_at);\nconst checkedDate = new Date(normalized.checked_at);\n\nconst safeDeadline = Number.isNaN(deadlineDate.getTime()) ? null : deadlineDate;\nconst safeChecked = Number.isNaN(checkedDate.getTime()) ? new Date() : checkedDate;\n\nconst overdueMs = safeDeadline ? Math.max(0, safeChecked.getTime() - safeDeadline.getTime()) : 0;\nconst overdueMinutes = Math.floor(overdueMs / 60000);\nconst overdueDays = Math.floor(overdueMinutes / 1440);\nconst overdueHours = Math.floor((overdueMinutes % 1440) / 60);\nconst overdueMins = overdueMinutes % 60;\n\nlet overdueText = \u00270m\u0027;\nif (overdueDays \u003e 0) {\n  overdueText = `${overdueDays}d ${overdueHours}h ${overdueMins}m`;\n} else if (overdueHours \u003e 0) {\n  overdueText = `${overdueHours}h ${overdueMins}m`;\n} else {\n  overdueText = `${overdueMins}m`;\n}\n\nconst target = String(normalized.target || \u0027\u0027).toUpperCase();\nconst recipientName = target === \u0027GIRI\u0027 ? \u0027Giri\u0027 : \u0027MD\u0027;\nconst escalationLevel = target === \u0027GIRI\u0027 ? \u0027Level 1 - GIRI\u0027 : \u0027Level 2 - MD\u0027;\nconst roleInstruction = target === \u0027GIRI\u0027\n  ? \u0027This order has stayed in the same state beyond SLA. Please take immediate action and update it.\u0027\n  : \u0027This order is still in the same state; if this continues, planned T\u0026A cannot be achieved.\u0027;\n\nconst deadlineText = safeDeadline ? safeDeadline.toISOString().replace(\u0027T\u0027, \u0027 \u0027).replace(\u0027.000Z\u0027, \u0027 UTC\u0027) : String(normalized.deadline_at || \u0027-\u0027);\n\nconst requestBody = {\n  messaging_product: \u0027whatsapp\u0027,\n  to: normalized.contact,\n  type: \u0027template\u0027,\n  template: {\n    name: templateName,\n    language: { code: \u0027en_US\u0027 },\n    components: [\n      {\n        type: \u0027body\u0027,\n        parameters: [\n          { type: \u0027text\u0027, text: recipientName },\n          { type: \u0027text\u0027, text: normalized.order_code },\n          { type: \u0027text\u0027, text: normalized.customer_name },\n          { type: \u0027text\u0027, text: normalized.status },\n          { type: \u0027text\u0027, text: deadlineText },\n          { type: \u0027text\u0027, text: overdueText },\n          { type: \u0027text\u0027, text: escalationLevel },\n          { type: \u0027text\u0027, text: roleInstruction }\n        ]\n      }\n    ]\n  }\n};\n\nreturn [{\n  json: {\n    ok: true,\n    statusCode: 200,\n    normalized,\n    requestBody\n  }\n}];"
