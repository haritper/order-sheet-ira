FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me
DATABASE_URL=postgresql+psycopg2://ordersheet:ordersheet@db:5432/ordersheet
UPLOAD_DIR=/app/data/uploads
PDF_OUTPUT_DIR=/app/data/pdfs
STORAGE_BACKEND=local
S3_BUCKET=
S3_PREFIX=
AWS_REGION=ap-south-1
TIMEZONE=Asia/Kolkata
OPENAI_API_KEY=
OPENAI_ROSTER_MODEL=gpt-4.1-mini
OPENAI_VALIDATOR_MODEL=gpt-4.1
AI_VERIFY_ENABLED=true
AI_VERIFY_MODEL=gpt-4o
CUTTING_PLAN_SOURCE=deterministic
WORK_TIMING_ALERT_MODE=log
WORK_TIMING_GIRI_CONTACT=
WORK_TIMING_MD_CONTACT=
WORK_TIMING_WEBHOOK_URL=
WORK_TIMING_WEBHOOK_TOKEN=
WORK_TIMING_WEBHOOK_TIMEOUT_SECONDS=15
CUSTOMER_PLAN_WEBHOOK_ENABLED=true
CUSTOMER_PLAN_WEBHOOK_URL=
CUSTOMER_PLAN_WEBHOOK_TOKEN=
CUSTOMER_PLAN_WEBHOOK_TIMEOUT_SECONDS=15
